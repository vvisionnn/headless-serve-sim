{
  "name": "headless-serve-sim",
  "version": "0.0.23",
  "type": "module",
  "author": {
    "name": "Evan Bacon",
    "email": "baconbrix@gmail.com",
    "url": "https://evanbacon.dev"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vvisionnn/headless-serve-sim.git",
    "directory": "packages/headless-serve-sim"
  },
  "homepage": "https://github.com/vvisionnn/headless-serve-sim#readme",
  "bugs": {
    "url": "https://github.com/vvisionnn/headless-serve-sim/issues"
  },
  "bin": {
    "headless-serve-sim": "dist/headless-serve-sim.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/headless-serve-sim.js",
    "dist/middleware.js",
    "dist/middleware.cjs",
    "dist/simcam/libSimCameraInjector.dylib",
    "dist/simcam/headless-serve-sim-camera-helper",
    "dist/simax/headless-serve-sim-ax-settings",
    "src/ax-shared.ts",
    "src/ax.ts",
    "src/debug.ts",
    "src/device-frame-profile.ts",
    "src/device.ts",
    "src/exec-ws.ts",
    "src/middleware.ts",
    "src/runtime.ts",
    "src/sim-log-stream.ts",
    "src/state.ts",
    "src/ui-settings.ts",
    "bin/headless-serve-sim-bin",
    "Sources/SimCameraInjector/SimCameraInjector.m",
    "Sources/SimCameraInjector/SimCam*.h",
    "Sources/SimCameraInjector/SimCam*.m",
    "Sources/SimCameraInjector/include/SimCamShared.h",
    "Sources/SimCameraInjector/build.sh",
    "Sources/SimCameraHelper/main.m",
    "Sources/SimCameraHelper/build.sh",
    "Sources/SimAXSettings/sim-ax-settings.m",
    "Sources/SimAXSettings/build.sh"
  ],
  "exports": {
    "./middleware": {
      "require": "./dist/middleware.cjs",
      "import": "./dist/middleware.js",
      "types": "./src/middleware.ts"
    },
    "./state": {
      "import": "./src/state.ts",
      "types": "./src/state.ts"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:swift": "./build.sh",
    "benchmark:stream-quality": "bun run scripts/stream-quality-benchmark.ts",
    "test:adaptive": "DEVELOPER_DIR=$(xcode-select -p) swiftc Sources/SimStreamHelper/AdaptiveController.swift scripts/adaptive-controller-selftest.swift -o /tmp/adaptive-selftest && /tmp/adaptive-selftest",
    "test:metrics": "swiftc Sources/SimStreamHelper/ProcessMetrics.swift scripts/process-metrics-selftest.swift -o /tmp/process-metrics-selftest && /tmp/process-metrics-selftest",
    "test:snapshot": "swiftc Sources/SimStreamHelper/FrameSnapshotter.swift scripts/frame-snapshot-selftest.swift -o /tmp/frame-snapshot-selftest && /tmp/frame-snapshot-selftest",
    "dev": "bun run dev.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/debug": "^4.1.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "debug": "^4.4.3",
    "bun-plugin-tailwind": "^0.1.2",
    "commander": "^14.0.1",
    "preact": "^10.29.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "headless-serve-sim-client": "^0.1.16",
    "inspect-webkit": "^0.0.5",
    "ws": "^8.21.0"
  }
}
