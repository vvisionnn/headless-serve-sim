{
  "name": "headless-serve-sim",
  "version": "0.0.25",
  "type": "module",
  "author": {
    "name": "Evan Bacon",
    "email": "baconbrix@gmail.com",
    "url": "https://evanbacon.dev"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vvisionnn/headless-serve-sim.git",
    "directory": "packages/headless-serve-sim"
  },
  "homepage": "https://github.com/vvisionnn/headless-serve-sim#readme",
  "bugs": {
    "url": "https://github.com/vvisionnn/headless-serve-sim/issues"
  },
  "bin": {
    "headless-serve-sim": "dist/headless-serve-sim.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/headless-serve-sim.js",
    "dist/headless-serve-sim-bin",
    "dist/middleware.js",
    "dist/middleware.cjs",
    "dist/native-sources",
    "dist/simcam/libSimCameraInjector.dylib",
    "dist/simcam/headless-serve-sim-camera-helper",
    "dist/simax/headless-serve-sim-ax-settings",
    "src/ax-shared.ts",
    "src/ax.ts",
    "src/debug.ts",
    "src/device-frame-profile.ts",
    "src/device.ts",
    "src/exec-ws.ts",
    "src/middleware.ts",
    "src/runtime.ts",
    "src/sim-log-stream.ts",
    "src/state.ts",
    "src/ui-settings.ts"
  ],
  "exports": {
    "./middleware": {
      "require": "./dist/middleware.cjs",
      "import": "./dist/middleware.js",
      "types": "./src/middleware.ts"
    },
    "./state": {
      "import": "./src/state.ts",
      "types": "./src/state.ts"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:swift": "bun run --cwd ../headless-serve-sim-binary build:swift",
    "benchmark:stream-quality": "bun run scripts/stream-quality-benchmark.ts",
    "benchmark:stream-performance": "bun run scripts/stream-performance-benchmark.ts",
    "report:stream-performance": "bun run scripts/stream-performance-report.ts",
    "test:adaptive": "bun run --cwd ../headless-serve-sim-binary test:adaptive",
    "test:metrics": "bun run --cwd ../headless-serve-sim-binary test:metrics",
    "test:snapshot": "bun run --cwd ../headless-serve-sim-binary test:snapshot",
    "test:frame-admission": "bun run --cwd ../headless-serve-sim-binary test:frame-admission",
    "test:stream-format": "bun run --cwd ../headless-serve-sim-binary test:stream-format",
    "test:keyframe-request": "bun run --cwd ../headless-serve-sim-binary test:keyframe-request",
    "test:avcc-send-queue": "bun run --cwd ../headless-serve-sim-binary test:avcc-send-queue",
    "dev": "bun run dev.ts"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/debug": "^4.1.13",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/ws": "^8.18.1",
    "debug": "^4.4.3",
    "bun-plugin-tailwind": "^0.1.2",
    "commander": "^14.0.1",
    "preact": "^10.29.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.1.7"
  },
  "dependencies": {
    "headless-serve-sim-client": "workspace:^",
    "inspect-webkit": "^0.0.5",
    "ws": "^8.21.0"
  }
}
