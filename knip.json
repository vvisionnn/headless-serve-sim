{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignoreBinaries": ["swiftc", "xcode-select"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [".claude/skills/release-and-monitor/scripts/*.ts", "scripts/*.ts"]
    },
    "packages/headless-serve-sim": {
      "ignoreDependencies": ["preact"],
      "entry": [
        "src/index.ts",
        "src/__tests__/**/*.test.{ts,tsx}",
        "src/system-tests/**/*.system.ts",
        "src/client/client.tsx",
        "src/client/global.css",
        "scripts/build-trails.ts"
      ]
    },
    "packages/headless-serve-sim-client": {
      "entry": ["src/__tests__/**/*.test.{ts,tsx}"]
    }
  }
}
