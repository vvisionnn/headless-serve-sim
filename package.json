{
  "name": "headless-serve-sim-repo",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:swift": "bun run --cwd packages/headless-serve-sim-binary build:swift",
    "check": "bun run check:static && bun run test",
    "check:static": "bun run format:check && bun run lint && bun run typecheck && bun run check:test-safety && bun run check:host-command-seam && bun run knip",
    "check:host-command-seam": "bun run scripts/check-host-command-seam.ts",
    "check:test-safety": "bun run scripts/check-test-safety.ts",
    "format": "oxfmt --write package.json knip.json .oxlintrc.json .oxfmtrc.json '.github/**/*.{yml,yaml}' 'scripts/**/*.{ts,js,json}' 'packages/**/*.{ts,tsx,js,json,css,md}'",
    "format:check": "oxfmt --check package.json knip.json .oxlintrc.json .oxfmtrc.json '.github/**/*.{yml,yaml}' 'scripts/**/*.{ts,js,json}' 'packages/**/*.{ts,tsx,js,json,css,md}'",
    "knip": "knip",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives",
    "test": "bun run scripts/run-hermetic-tests.ts",
    "test:unit": "bun run scripts/run-hermetic-tests.ts",
    "typecheck": "tsc --noEmit"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.14",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "knip": "^6.12.2",
    "oxc-parser": "^0.140.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.2"
  }
}
